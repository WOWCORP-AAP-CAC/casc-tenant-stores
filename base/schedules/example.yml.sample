---
# Example schedules configuration — rename to .yml to activate.
# This file belongs in base/schedules/ and applies to ALL environments.
# For environment-specific overrides, place a .yml file in <env>/schedules/.
controller_schedules:
  - name: sch-stores-example
    description: "Example schedule — replace with your schedule"
    unified_job_template: jt-stores-example
    organization: "stores"
    rrule: "DTSTART;TZID=UTC:20260101T060000 RRULE:FREQ=WEEKLY;BYDAY=MO"
    enabled: false
