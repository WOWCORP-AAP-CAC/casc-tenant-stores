---
# Example credentials configuration — rename to .yml to activate.
# This file belongs in base/credentials/ and applies to ALL environments.
# For environment-specific overrides, place a .yml file in <env>/credentials/.
controller_credentials:
  - name: crd-stores-mch-example
    description: "Example machine credential — replace with your credential"
    organization: "stores"
    credential_type: Machine
    inputs:
      username: example_user
